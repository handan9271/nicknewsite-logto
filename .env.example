# DeepSeek API Key (在 Zeabur 环境变量里设置，不要提交到 Git)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 用户配置方式二选一：
# 方式 1 — 直接用项目根目录的 users.json 文件（本地开发推荐）
USERS_FILE=./users.json

# 方式 2 — 把用户列表 JSON 字符串写进环境变量（Zeabur 部署推荐）
# USERS_JSON=[{"username":"nick","password_hash":"8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92","display_name":"Nick 老师"}]

# 生产环境设为 true（HTTPS 时 cookie 才会带 secure 标志）
SECURE_COOKIE=false
