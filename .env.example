# ========================================
# 必需环境变量
# ========================================

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Logto 认证配置
LOGTO_ENDPOINT=https://your-region.logto.app/
LOGTO_APP_ID=your_logto_app_id_here
LOGTO_APP_SECRET=your_logto_app_secret_here

# ========================================
# 可选环境变量
# ========================================

# 应用基础 URL（通常自动检测，无需手动设置）
# BASE_URL=https://your-domain.com

# 数据存储路径
# DATA_STORAGE_PATH=./data

# 数据库连接（默认 SQLite，生产推荐 MySQL）
# DATABASE_URL=mysql+pymysql://user:pass@host:port/db

# CORS 配置（默认允许所有，生产环境请指定域名）
# CORS_ORIGINS=https://your-domain.com

# ========================================
# Logto 认证设置说明
# ========================================
# 1. 在 https://cloud.logto.io/ 创建应用（Traditional Web）
# 2. 配置回调 URL:
#    开发: http://localhost:8000/auth/callback
#    生产: https://your-domain.com/auth/callback
# 3. 配置登出重定向 URL:
#    开发: http://localhost:8000/
#    生产: https://your-domain.com/
